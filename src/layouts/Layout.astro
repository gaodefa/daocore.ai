---
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "DaoCore — The AI that actually does things. Your personal assistant on any platform.",
  canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://daocore.ai").href,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="DaoCore Blog" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://daocore.ai/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://daocore.ai/og-image.png" />

    <!-- Fonts: Clash Display + Satoshi from Fontshare with font-display swap for performance -->
    <link rel="preconnect" href="https://api.fontshare.com">
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin>
    <link href="https://api.fontshare.com/v2/css?f[]=clash-display@700,600,500&f[]=satoshi@400,500,700&display=swap" rel="stylesheet">

    <title>{title}</title>

    <script is:inline>
      (() => {
        const key = 'oc-theme';
        const saved = localStorage.getItem(key);
        const theme = saved === 'light' || saved === 'dark' ? saved : 'dark';
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>

    <style is:global>
      :root {
        /* Deep space palette with lobster accents */
        --bg-deep: #050810;
        --bg-surface: #0a0f1a;
        --bg-elevated: #111827;

        /* Lobster coral spectrum */
        --coral-bright: #ff4d4d;
        --coral-mid: #e63946;
        --coral-dark: #991b1b;

        /* Bioluminescent cyan */
        --cyan-bright: #00e5cc;
        --cyan-mid: #14b8a6;
        --cyan-glow: rgba(0, 229, 204, 0.4);

        /* Text */
        --text-primary: #f0f4ff;
        --text-secondary: #8892b0;
        --text-muted: #5a6480;

        /* Borders */
        --border-subtle: rgba(136, 146, 176, 0.15);
        --border-accent: rgba(255, 77, 77, 0.3);

        --surface-card: rgba(10, 15, 26, 0.65);
        --surface-card-strong: rgba(10, 15, 26, 0.8);
        --surface-overlay: rgba(0, 0, 0, 0.3);
        --surface-interactive: rgba(255, 255, 255, 0.1);
        --surface-interactive-hover: rgba(255, 255, 255, 0.2);
        --surface-cyan-soft: rgba(0, 229, 204, 0.15);
        --surface-coral-soft: rgba(255, 77, 77, 0.15);
        --surface-inset-highlight: rgba(255, 255, 255, 0.05);
        --newsletter-gradient:
          linear-gradient(
            135deg,
            rgba(255, 77, 77, 0.05) 0%,
            rgba(10, 15, 26, 0.8) 50%,
            rgba(0, 229, 204, 0.03) 100%
          );
        --press-featured-gradient:
          linear-gradient(135deg, rgba(255, 77, 77, 0.05) 0%, rgba(10, 15, 26, 0.7) 100%);
        --shadow-coral-soft: rgba(255, 77, 77, 0.15);
        --shadow-coral-mid: rgba(255, 77, 77, 0.25);
        --shadow-coral-strong: rgba(255, 77, 77, 0.35);
        --shadow-cyan-soft: rgba(0, 229, 204, 0.15);
        --shadow-github-soft: rgba(240, 244, 255, 0.1);
        --github-hover-color: #f0f4ff;
        --hero-title-start: #f0f4ff;
        --hero-title-end: #00e5cc;
        --logo-gradient-start: #ff4d4d;
        --logo-gradient-end: #991b1b;
        --logo-glow: rgba(255, 77, 77, 0.4);
        --logo-glow-hover: rgba(0, 229, 204, 0.6);

        /* Fonts */
        --font-display: 'Clash Display', system-ui, sans-serif;
        --font-body: 'Satoshi', system-ui, sans-serif;
        --font-mono: 'SF Mono', 'Fira Code', 'JetBrains Mono', monospace;
      }

      html[data-theme='light'] {
        --bg-deep: #fcfeff;
        --bg-surface: #ffffff;
        --bg-elevated: #f5f9ff;

        --coral-bright: #ef4b58;
        --coral-mid: #de3f4d;
        --coral-dark: #c43645;

        --cyan-bright: #008f87;
        --cyan-mid: #00766e;
        --cyan-glow: rgba(0, 143, 135, 0.24);

        --text-primary: #0b1220;
        --text-secondary: #2e405c;
        --text-muted: #5f7290;

        --border-subtle: rgba(15, 23, 42, 0.16);
        --border-accent: rgba(239, 75, 88, 0.34);

        --surface-card: rgba(255, 255, 255, 0.88);
        --surface-card-strong: rgba(255, 255, 255, 0.95);
        --surface-overlay: rgba(160, 174, 194, 0.26);
        --surface-interactive: rgba(15, 23, 42, 0.1);
        --surface-interactive-hover: rgba(15, 23, 42, 0.16);
        --surface-cyan-soft: rgba(0, 143, 135, 0.16);
        --surface-coral-soft: rgba(239, 75, 88, 0.16);
        --surface-inset-highlight: rgba(15, 23, 42, 0.06);
        --newsletter-gradient:
          linear-gradient(
            135deg,
            rgba(239, 75, 88, 0.11) 0%,
            rgba(255, 255, 255, 0.98) 52%,
            rgba(0, 143, 135, 0.12) 100%
          );
        --press-featured-gradient:
          linear-gradient(135deg, rgba(239, 75, 88, 0.13) 0%, rgba(255, 255, 255, 0.96) 100%);
        --shadow-coral-soft: rgba(239, 75, 88, 0.19);
        --shadow-coral-mid: rgba(239, 75, 88, 0.27);
        --shadow-coral-strong: rgba(239, 75, 88, 0.33);
        --shadow-cyan-soft: rgba(0, 143, 135, 0.22);
        --shadow-github-soft: rgba(11, 18, 32, 0.2);
        --github-hover-color: #0b1220;
        --hero-title-start: #c93342;
        --hero-title-end: #f04d5a;
        --logo-gradient-start: #ff7079;
        --logo-gradient-end: #ea4c59;
        --logo-glow: rgba(239, 75, 88, 0.2);
        --logo-glow-hover: rgba(0, 143, 135, 0.35);
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-body);
        background: var(--bg-deep);
        color: var(--text-primary);
        line-height: 1.6;
        min-height: 100vh;
        transition: background-color 0.25s ease, color 0.25s ease;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      html[data-theme='light'] body {
        background:
          radial-gradient(1200px circle at 12% -10%, rgba(224, 53, 67, 0.04), transparent 58%),
          radial-gradient(900px circle at 88% -12%, rgba(0, 143, 135, 0.05), transparent 56%),
          var(--bg-deep);
      }

      ::selection {
        background: var(--coral-bright);
        color: var(--bg-deep);
      }

      html[data-theme='light'] .stars {
        opacity: 0.28;
        filter: saturate(0.6);
      }

      html[data-theme='light'] .nebula {
        opacity: 0.45;
      }

      .theme-toggle {
        position: fixed;
        top: 11px;
        right: 24px;
        z-index: 999;
        width: 40px;
        height: 40px;
        display: grid;
        place-items: center;
        padding: 0;
        border-radius: 999px;
        border: 1px solid var(--border-subtle);
        background: var(--surface-card-strong);
        cursor: pointer;
        backdrop-filter: blur(10px);
        transition: all 0.2s ease;
      }

      .theme-toggle:hover {
        border-color: var(--border-accent);
        transform: translateY(-1px);
        box-shadow: 0 10px 24px color-mix(in srgb, var(--coral-bright) 20%, transparent);
      }

      .theme-toggle:focus-visible {
        outline: 2px solid var(--cyan-bright);
        outline-offset: 2px;
      }

      .theme-toggle-icon {
        font-size: 1.05rem;
        line-height: 1;
        color: var(--text-secondary);
        transition: transform 0.2s ease, color 0.2s ease;
      }

      .theme-toggle:hover .theme-toggle-icon {
        color: var(--text-primary);
        transform: rotate(10deg) scale(1.04);
      }

      @media (max-width: 640px) {
        .theme-toggle {
          top: 11px;
          right: 12px;
          width: 36px;
          height: 36px;
        }
      }
    </style>
  </head>
  <body>
        <!-- Preloader: 2.5D Sword-Flight Cinematic Intro -->
    <script is:inline>
(()=>{
if(location.pathname!=='/'&&location.pathname!=='')return;
var W=window.innerWidth,H=window.innerHeight,ov=document.createElement('div');
ov.style.cssText='position:fixed;inset:0;z-index:999999;background:#050810;overflow:hidden;pointer-events:none';
var cv=document.createElement('canvas');cv.width=W;cv.height=H;
cv.style.cssText='position:absolute;inset:0;width:100%;height:100%';ov.appendChild(cv);

var sk=document.createElement('button');
sk.textContent='跳过 ›';
sk.style.cssText='position:fixed;bottom:24px;right:24px;z-index:10;padding:8px 18px;border:1px solid rgba(255,255,255,.15);border-radius:6px;background:rgba(255,255,255,.05);color:rgba(255,255,255,.4);font-size:13px;font-family:inherit;cursor:pointer;opacity:0;transition:opacity .4s;pointer-events:auto';
ov.appendChild(sk);

var lw=document.createElement('div');
lw.style.cssText='position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:5;opacity:0;transition:opacity .8s';
var lh=document.createElement('div');lh.textContent='DaoCore';
lh.style.cssText='font-family:"Clash Display",system-ui,sans-serif;font-size:clamp(48px,10vw,96px);font-weight:700;color:#f0f4ff;letter-spacing:2px;text-shadow:0 0 40px rgba(255,77,77,.5),0 0 80px rgba(0,229,204,.3)';
lw.appendChild(lh);
var ls=document.createElement('div');ls.textContent='The AI that actually does things.';
ls.style.cssText='font-family:"Satoshi",system-ui,sans-serif;font-size:clamp(14px,2.5vw,20px);color:rgba(255,255,255,.6);margin-top:12px;letter-spacing:1px';
lw.appendChild(ls);
ov.appendChild(lw);
document.documentElement.appendChild(ov);

var X=cv.getContext('2d'),W2=W,H2=H,CX=W/2,CY=H/2,rn=true,t0=performance.now(),skd=false,ra=Math.random;
function n(a,b){return ra()*(b-a)+a}
function l(a,b,t){return a+(b-a)*t}

// Stars
var SS=[];
for(var i=0;i<180;i++)SS.push({x:n(0,W2),y:n(0,H2),sz:n(.3,1.5),sp:n(.1,.4),ph:n(0,6.28)});
// Speed lines
var SL=[];
for(var i=0;i<35;i++)SL.push({x:n(0,W2),y:n(0,H2),l:n(30,120),sp:n(10,30),op:n(.1,.4),th:n(.5,1.5)});
// Clouds
var CL=[];
for(var i=0;i<15;i++)CL.push({x:n(0,W2),y:n(H2*.4,H2*.8),w:n(120,300),h:n(15,50),sp:n(.4,1.2),op:n(.05,.12)});
// Mountain peaks
function MP(c){var r=[];for(var i=0;i<c;i++)r.push({x:i*W2/(c-1),y:H2*(.55+n(.08,.2)-(i%3)*.04)});return r;}
var MF=MP(12),MM=MP(10),MN=MP(8);

function dwMt(ps,sc,cl,alpha){
  X.save();X.fillStyle=cl;X.globalAlpha=alpha;
  X.beginPath();X.moveTo(-10,H2+10);
  for(var i=0;i<ps.length;i++){
    var px=((ps[i].x-sc)%(W2+100)+W2+100)%(W2+100)-50;
    X.lineTo(px,ps[i].y);
  }
  X.lineTo(W2+10,H2+10);X.closePath();X.fill();
  X.restore();
}

function dwCult(cx,cy,t){
  var sx=cx,sy=cy+30,sw=Math.sin(t*.005)*2,br=Math.sin(t*.003)*1.5;
  // Sword glow
  var g=X.createRadialGradient(sx,sy,0,sx,sy,45);
  g.addColorStop(0,'rgba(0,229,204,.3)');g.addColorStop(.5,'rgba(255,77,77,.12)');g.addColorStop(1,'rgba(0,229,204,0)');
  X.fillStyle=g;X.beginPath();X.ellipse(sx,sy,60,20,0,0,Math.PI*2);X.fill();
  // Blade
  X.save();X.translate(sx,sy);X.rotate(Math.sin(t*.003)*.03);
  X.fillStyle='#d0e8f0';X.beginPath();
  X.moveTo(-55,0);X.lineTo(50,-4);X.lineTo(65,0);X.lineTo(50,4);X.closePath();X.fill();
  X.strokeStyle='rgba(255,255,255,.4)';X.lineWidth=1;X.beginPath();
  X.moveTo(-55,0);X.lineTo(65,0);X.stroke();
  X.fillStyle='#c43645';X.fillRect(-63,-5,8,10);
  X.fillStyle='#8b4513';X.fillRect(-80,-3,17,6);
  X.fillStyle='#ff4d4d';X.beginPath();X.arc(-82,0,3,0,Math.PI*2);X.fill();
  X.restore();
  // Body
  X.save();X.translate(sx-10+sw,sy-35);
  X.fillStyle='#1a1a2e';X.beginPath();
  X.moveTo(0,0);X.lineTo(-16,42+br);X.lineTo(16,42+br);X.closePath();X.fill();
  X.fillStyle='rgba(200,50,50,.3)';X.beginPath();
  X.moveTo(0,8);X.lineTo(-10,37+br);X.lineTo(10,37+br);X.closePath();X.fill();
  X.fillStyle='#c43645';X.fillRect(-12,20,24,3);
  // Head
  X.fillStyle='#f0d5b8';X.beginPath();X.arc(0,-8,9,0,Math.PI*2);X.fill();
  X.fillStyle='#111';X.beginPath();X.arc(0,-10,9,Math.PI,0);X.fill();
  // Hair ribbons flowing
  var rb=Math.sin(t*.006)*8;
  X.strokeStyle='#c43645';X.lineWidth=2.5;
  X.beginPath();X.moveTo(0,-13);X.quadraticCurveTo(-16+rb,-22,-28+rb,-12+rb*.5);X.stroke();
  X.beginPath();X.moveTo(0,-11);X.quadraticCurveTo(-20+rb*.7,-27,-36+rb,-16+rb*.3);X.stroke();
  // Arms
  X.strokeStyle='#f0d5b8';X.lineWidth=2.5;
  X.beginPath();X.moveTo(-4,8);X.quadraticCurveTo(-22,4,-26,12);X.stroke();
  X.beginPath();X.moveTo(4,8);X.quadraticCurveTo(18,12,14,22);X.stroke();
  // Robe tails
  var f1=Math.sin(t*.007)*10,f2=Math.sin(t*.005+1)*8;
  X.fillStyle='rgba(26,26,46,.85)';
  X.beginPath();X.moveTo(-8,39+br);X.quadraticCurveTo(-24+f1,50,-36+f1,36+f1*.3);X.quadraticCurveTo(-20,46,-8,44+br);X.closePath();X.fill();
  X.beginPath();X.moveTo(8,39+br);X.quadraticCurveTo(20+f2,52,32+f2,40+f2*.3);X.quadraticCurveTo(16,48,8,44+br);X.closePath();X.fill();
  X.restore();
}

function fr(no){
  if(!rn)return;
  var t=no-t0;
  X.clearRect(0,0,W2,H2);
  var bg=X.createLinearGradient(0,0,0,H2);
  bg.addColorStop(0,'#030508');bg.addColorStop(.5,'#050810');bg.addColorStop(1,'#0a0f1a');
  X.fillStyle=bg;X.fillRect(0,0,W2,H2);

  var p;if(t<1200)p=0;else if(t<2800)p=1;else if(t<5200)p=2;else if(t<7000)p=3;else p=4;
  var pt=[0,1200,2800,5200,7000],pd=[1200,1600,2400,1800,1500];
  var pt2=Math.min((t-pt[p])/pd[p],1);
  var sm=p>=2?l(1,7,Math.min(pt2*1.5,1)):p>=1?l(.5,1,pt2):l(0,.5,pt2);
  var moonOp=p>=1?l(0,.12,Math.min(pt2*2,1)):0;
  if(p>=1){var mg=X.createRadialGradient(W2*.75,H2*.18,0,W2*.75,H2*.18,100);
    mg.addColorStop(0,'rgba(255,200,150,'+moonOp+')');mg.addColorStop(.3,'rgba(255,150,100,'+(moonOp*.3)+')');mg.addColorStop(1,'rgba(255,100,50,0)');
    X.fillStyle=mg;X.fillRect(0,0,W2,H2);}

  // Stars
  for(var i=0;i<SS.length;i++){
    var s=SS[i],sx=((s.x-t*s.sp*sm*.02)%W2+W2)%W2,sy=s.y;
    var al=(.5+.5*Math.sin(t*.003+s.ph))*(p>=0?Math.min(t/700,1):0);
    if(p>=2){var ll=s.sz*sm*8;
      X.strokeStyle='rgba(200,220,255,'+al*.6+')';X.lineWidth=s.sz*.5;
      X.beginPath();X.moveTo(sx,sy);X.lineTo(sx+ll,sy);X.stroke();
    }else{X.fillStyle='rgba(200,220,255,'+al+')';X.beginPath();X.arc(sx,sy,s.sz,0,Math.PI*2);X.fill();}}

  // Mountains
  var sc_far=t*(p>=1?l(.06,.4,pt2):.02),sc_mid=t*(p>=1?l(.1,.9,pt2):.04),sc_near=t*(p>=1?l(.2,5,Math.min(pt2*1.5,1)):.06);
  dwMt(MF,sc_far,'rgba(12,18,32,.65)',l(0,.65,Math.min(pt2*3,1)));
  dwMt(MM,sc_mid,'rgba(8,12,25,.75)',l(0,.75,Math.min(pt2*2,1)));
  dwMt(MN,sc_near,'rgba(5,8,15,.85)',l(0,.85,Math.min(pt2*2,1)));

  // Clouds
  var cs=p>=2?l(.3,3.5,pt2):l(.1,.3,pt2);
  for(var i=0;i<CL.length;i++){
    var c=CL[i],cx=((c.x-t*c.sp*cs*.1)%W2+W2)%W2,cy=c.y;
    var co=c.op*l(0,1,Math.min(pt2*2,1));
    var cg=X.createRadialGradient(cx,cy,0,cx,cy,c.w*.4);
    cg.addColorStop(0,'rgba(200,200,220,'+co+')');cg.addColorStop(1,'rgba(200,200,220,0)');
    X.fillStyle=cg;X.beginPath();X.ellipse(cx,cy,c.w*.5,c.h*.5,0,0,Math.PI*2);X.fill();
  }

  // Speed lines
  if(p>=2){var slOp=l(0,.5,pt2);
    for(var i=0;i<SL.length;i++){var sl=SL[i],slx=((sl.x-t*sl.sp*.15)%W2+W2)%W2;
      X.strokeStyle='rgba(255,255,255,'+(sl.op*slOp)+')';X.lineWidth=sl.th;
      X.beginPath();X.moveTo(slx,sl.y);X.lineTo(slx+sl.l*sm*.5,sl.y);X.stroke();}}

  // Cultivator
  var sv=p>=0?l(0,1,Math.min(pt2*3,1)):0;
  if(sv>0){X.globalAlpha=sv;dwCult(W2*.5,H2*.42,t);X.globalAlpha=1;}

  // Front cloud wisps
  for(var i=0;i<6;i++){
    var fcx=((i*W2/6-t*cs*.6)%W2+W2)%W2,fcy=H2*.72+i*28;
    var fOp=l(0,.06,Math.min(pt2*2,1));
    var fg=X.createRadialGradient(fcx,fcy,0,fcx,fcy,70);
    fg.addColorStop(0,'rgba(180,180,200,'+fOp+')');fg.addColorStop(1,'rgba(180,180,200,0)');
    X.fillStyle=fg;X.beginPath();X.ellipse(fcx,fcy,80,20,0,0,Math.PI*2);X.fill();
  }

  // Arrival
  if(p>=4){var at=(t-pt[4])/pd[4];
    if(at<.15){var fo=(1-at/.15)*.6;
      X.fillStyle='rgba(255,255,255,'+fo+')';X.fillRect(0,0,W2,H2);}
    if(at>.2)lw.style.opacity=String(Math.min((at-.2)/.4,1));
    if(at>.6)ov.style.opacity=String(1-(at-.6)/.4);
    if(at>=1){rn=false;if(ov.parentNode)ov.parentNode.removeChild(ov);return;}}
  requestAnimationFrame(fr);
}

function ds(){if(skd)return;skd=true;sk.style.opacity='0';
  t0=performance.now()-7000;rn=true;requestAnimationFrame(fr);}
sk.addEventListener('click',ds);
document.addEventListener('keydown',function(e){if(e.key==='Escape'||e.key===' '){ds();e.preventDefault();}});
setTimeout(function(){sk.style.opacity='1'},800);
requestAnimationFrame(fr);
})();
    </script>
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch color theme">
      <span class="theme-toggle-icon" data-theme-icon aria-hidden="true"></span>
    </button>
    <slot />
    <Analytics />

    <script is:inline>
      (() => {
        const key = 'oc-theme';
        const root = document.documentElement;
        const toggle = document.querySelector('[data-theme-toggle]');
        const icon = document.querySelector('[data-theme-icon]');
        if (!toggle || !icon) return;

        const applyTheme = (theme, persist = true) => {
          root.dataset.theme = theme;
          root.style.colorScheme = theme;
          const isDark = theme === 'dark';
          icon.textContent = isDark ? '☀' : '☾';
          toggle.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
          toggle.setAttribute('title', isDark ? 'Switch to light mode' : 'Switch to dark mode');
          if (persist) {
            localStorage.setItem(key, theme);
          }
        };

        toggle.addEventListener('click', () => {
          const next = root.dataset.theme === 'light' ? 'dark' : 'light';
          applyTheme(next);
        });

        const current = root.dataset.theme === 'light' ? 'light' : 'dark';
        applyTheme(current, false);
      })();
    </script>
  </body>
</html>
